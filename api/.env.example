# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/budokan

# Server port
PORT=3003

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Required by /players/:address/rewards — denshokan API endpoint for the
# same chain (mainnet/sepolia) and the deployed Budokan contract address.
# When unset the endpoint returns 503.
DENSHOKAN_API_URL=https://denshokan-api-production.up.railway.app
BUDOKAN_ADDRESS=0x0596ced030e74ebc37f33607f07ecd5a62eff22cdc4ae31fe2d724040c1bdc0b
