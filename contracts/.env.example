# Budokan Deployment Configuration
# Copy this file to .env and fill in the values

# Required: Profile from snfoundry.toml (default, sepolia, mainnet)
PROFILE=sepolia

# Optional: Owner address for Budokan and Viewer contracts
# If not set, will use the deployer account from snfoundry.toml
# OWNER_ADDRESS=0x...

# Required: Default ERC20 token address for entry fees
DEFAULT_TOKEN_ADDRESS=0x049d36570d4e46f48e99674bd3fcc84644ddd6b96f7c741b1562b82f9e004dc7

# Optional: Skip confirmation prompt
# SKIP_CONFIRMATION=true
